# engram environment configuration
# Copy to .env and source before using engram, or export in your shell profile

# Jina AI API key -- required for embeddings, reranking, and URL ingestion
# Get one at: https://jina.ai/
export JINA_API_KEY=your_key_here

# Optional: default database path (overrides .engram in cwd)
# export ENGRAM_DB_PATH=$HOME/.engram/default

# Tracing level (error, warn, info, debug, trace)
# export RUST_LOG=engram=info
